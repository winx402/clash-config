#!name=YouTube Premium 自动选路
#!desc=为 select 策略组按 YouTube 返回地区选择 Premium 可用节点；自动策略组安全跳过。
#!arguments=TARGET_GROUP:Youtube,REGION_ORDER:"sg,jp,us,other"
#!arguments-desc=TARGET_GROUP：顶层 select 策略组的精确名称。\n\nREGION_ORDER：YouTube 返回国家代码的优先顺序，支持任意两位代码和 other。
#!requirement=(SYSTEM = 'macOS' || SYSTEM = 'iOS')

[Script]
YouTube Premium 自动检测 = type=cron,cronexp="*/15 * * * *",script-path=https://raw.githubusercontent.com/winx402/clash-config/main/youtube-premium-auto-surge.js,script-update-interval=86400,timeout=600,engine=webview,argument="TARGET_GROUP={{{TARGET_GROUP}}}&REGION_ORDER={{{REGION_ORDER}}}&RUN_MODE=cron"
立即检测 YouTube Premium = type=generic,script-path=https://raw.githubusercontent.com/winx402/clash-config/main/youtube-premium-auto-surge.js,script-update-interval=86400,timeout=600,engine=webview,argument="TARGET_GROUP={{{TARGET_GROUP}}}&REGION_ORDER={{{REGION_ORDER}}}&RUN_MODE=manual"
